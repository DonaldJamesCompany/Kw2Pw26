<Window x:Class="Kw2Pw26.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Kw2Pw26"
        mc:Ignorable="d"
        Title="CSV → SQL Server Importer"
        SizeToContent="Height"
        Width="620"
        MinWidth="520"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0,0,4,0"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="22"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="2,0"/>
        </Style>
        <Style x:Key="SmallBtn" TargetType="Button">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="BottomBtn" TargetType="Button">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Margin" Value="4,0"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="8">

        <!-- ── BOTTOM BUTTON BAR (docked first so it stays pinned) ── -->
        <Border DockPanel.Dock="Bottom" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Padding="0,6,0,0" Margin="0,6,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="BtnClear"    Content="CLEAR"    Style="{StaticResource BottomBtn}" Click="BtnClear_Click"/>
                <Button x:Name="BtnImport"   Content="IMPORT"   Style="{StaticResource BottomBtn}" Click="BtnImport_Click" IsEnabled="False"/>
                <Button x:Name="BtnViewLog"  Content="VIEW LOG" Style="{StaticResource BottomBtn}" Width="80" Click="BtnViewLog_Click"/>
                <Button x:Name="BtnExit"     Content="EXIT"     Style="{StaticResource BottomBtn}" Click="BtnExit_Click"/>
            </StackPanel>
        </Border>

        <!-- ── MAIN CONTENT ── -->
        <StackPanel>
            <StackPanel.Resources>
                <Style TargetType="GroupBox">
                    <Setter Property="Margin" Value="0,0,0,6"/>
                </Style>
            </StackPanel.Resources>

            <!-- Connection String -->
            <GroupBox Header="Connection String" Padding="6,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtConnectionString"
                             Grid.Column="0"
                             ToolTip="Enter SQL Server connection string"
                             Text="Server=.;Database=MyDb;Trusted_Connection=True;TrustServerCertificate=True;"/>
                    <Button x:Name="BtnTest" Content="TEST" Grid.Column="1"
                            Style="{StaticResource SmallBtn}" Margin="4,0,0,0"
                            Click="BtnTest_Click"/>
                </Grid>
            </GroupBox>

            <!-- Folder Selection -->
            <GroupBox Header="CSV Folder" Padding="6,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtFolder" Grid.Column="0" IsReadOnly="True" Background="#F5F5F5"
                             ToolTip="Selected folder containing CSV files"/>
                    <Button x:Name="BtnBrowse" Content="Browse…" Grid.Column="1"
                            Style="{StaticResource SmallBtn}" Margin="4,0,0,0"
                            Click="BtnBrowse_Click"/>
                </Grid>
            </GroupBox>

            <!-- CSV Config Files (DBFCHK.CSV / DBF.CSV) -->
            <GroupBox Header="CSV Config Location (DBFCHK.CSV &amp; DBF.CSV)" Padding="6,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtCsvConfigFolder" Grid.Column="0" IsReadOnly="True" Background="#F5F5F5"
                             ToolTip="Folder containing DBFCHK.CSV and DBF.CSV"/>
                    <Button x:Name="BtnBrowseCsvConfig" Content="Browse…" Grid.Column="1"
                            Style="{StaticResource SmallBtn}" Margin="4,0,0,0"
                            Click="BtnBrowseCsvConfig_Click"/>
                    <Button x:Name="BtnCheck" Content="CHECK" Grid.Column="2"
                            Style="{StaticResource SmallBtn}" Margin="4,0,0,0"
                            Click="BtnCheck_Click"/>
                </Grid>
            </GroupBox>

            <!-- File List -->
            <GroupBox Header="CSV Files" Padding="6,4">
                <StackPanel>
                    <!-- File list toolbar -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4" HorizontalAlignment="Left">
                        <Button x:Name="BtnSelectAll"  Content="SELECT ALL"  Style="{StaticResource SmallBtn}" Margin="0,0,4,0" Click="BtnSelectAll_Click"/>
                        <Button x:Name="BtnSelectNone" Content="SELECT NONE" Style="{StaticResource SmallBtn}" Margin="0,0,4,0" Click="BtnSelectNone_Click"/>
                        <Button x:Name="BtnClearFiles" Content="CLEAR FILES" Style="{StaticResource SmallBtn}" Click="BtnClearFiles_Click"/>
                    </StackPanel>
                    <!-- Scrollable checkbox list -->
                    <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="2">
                        <ScrollViewer Height="120" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="FileList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}"
                                                  Content="{Binding FileName}"
                                                  Margin="4,2"
                                                  FontSize="12"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </GroupBox>

            <!-- Import Options -->
            <GroupBox Header="Import Options" Padding="6,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ROW 1: Database exists -->
                    <Label Grid.Row="0" Grid.Column="0" Content="Database exists:"/>
                    <ComboBox x:Name="CmbDatabaseExists" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Error &amp; Exit"/>
                        <ComboBoxItem Content="Overwrite"/>
                        <ComboBoxItem Content="Skip"/>
                        <ComboBoxItem Content="Ask"/>
                    </ComboBox>
                    <Label Grid.Row="0" Grid.Column="3" Content="Log?" Margin="6,0,2,0"/>
                    <ComboBox x:Name="CmbDatabaseLog" Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="5"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Errors only"/>
                        <ComboBoxItem Content="All"/>
                        <ComboBoxItem Content="None"/>
                    </ComboBox>

                    <!-- ROW 2: Table exists -->
                    <Label Grid.Row="2" Grid.Column="0" Content="Table exists:"/>
                    <ComboBox x:Name="CmbTableExists" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Error &amp; Exit"/>
                        <ComboBoxItem Content="Overwrite"/>
                        <ComboBoxItem Content="Skip"/>
                        <ComboBoxItem Content="Ask"/>
                    </ComboBox>
                    <Label Grid.Row="2" Grid.Column="3" Content="Log?" Margin="6,0,2,0"/>
                    <ComboBox x:Name="CmbTableLog" Grid.Row="2" Grid.Column="4" Grid.ColumnSpan="5"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Errors only"/>
                        <ComboBoxItem Content="All"/>
                        <ComboBoxItem Content="None"/>
                    </ComboBox>

                    <!-- ROW 3: Record exists -->
                    <Label Grid.Row="4" Grid.Column="0" Content="Record exists:"/>
                    <ComboBox x:Name="CmbRecordExists" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Error &amp; Exit"/>
                        <ComboBoxItem Content="Overwrite"/>
                        <ComboBoxItem Content="Skip"/>
                        <ComboBoxItem Content="Ask"/>
                    </ComboBox>
                    <Label Grid.Row="4" Grid.Column="3" Content="Log?" Margin="6,0,2,0"/>
                    <ComboBox x:Name="CmbRecordLog" Grid.Row="4" Grid.Column="4" Grid.ColumnSpan="5"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Errors only"/>
                        <ComboBoxItem Content="All"/>
                        <ComboBoxItem Content="None"/>
                    </ComboBox>

                    <!-- ROW 4: Max errors -->
                    <Label Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3" Content="Number errors before QUIT:"/>
                    <TextBox x:Name="TxtMaxErrors" Grid.Row="6" Grid.Column="3" Grid.ColumnSpan="6"
                             Width="60" HorizontalAlignment="Left" Margin="4,0,0,0"
                             Text="10" ToolTip="Maximum errors before aborting import (blank = 10)"/>

                    <!-- ROW 5: Import System Tables -->
                    <Label Grid.Row="8" Grid.Column="0" Content="Import System Tables?"/>
                    <ComboBox x:Name="CmbImportSystemTables" Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Yes"/>
                        <ComboBoxItem Content="No"/>
                    </ComboBox>
                    <Label Grid.Row="8" Grid.Column="3" Content="DB Name:" Margin="6,0,2,0"/>
                    <TextBox x:Name="TxtSystemDbName" Grid.Row="8" Grid.Column="4" Grid.ColumnSpan="5"
                             Text="PcaWorks26" ToolTip="System tables database name"/>

                    <!-- ROW 6: Import Company Tables -->
                    <Label Grid.Row="10" Grid.Column="0" Content="Import Company Tables?"/>
                    <ComboBox x:Name="CmbImportCompanyTables" Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="2"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Yes"/>
                        <ComboBoxItem Content="No"/>
                    </ComboBox>
                    <Label Grid.Row="10" Grid.Column="3" Content="DB Name:" Margin="6,0,2,0"/>
                    <TextBox x:Name="TxtCompanyDbName" Grid.Row="10" Grid.Column="4" Grid.ColumnSpan="5"
                             Text="Pca2026" ToolTip="Company tables database name"/>

                    <!-- ROW 7: Save DB config .ini -->
                    <Label Grid.Row="12" Grid.Column="0" Content="Save DB config?"/>
                    <ComboBox x:Name="CmbSaveConfig" Grid.Row="12" Grid.Column="1" Grid.ColumnSpan="2"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Yes"/>
                        <ComboBoxItem Content="No"/>
                    </ComboBox>
                    <Label Grid.Row="12" Grid.Column="3" Content=".ini File:" Margin="6,0,2,0"/>
                    <Grid Grid.Row="12" Grid.Column="4" Grid.ColumnSpan="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtIniFolder" Grid.Column="0" IsReadOnly="True" Background="#F5F5F5"
                                 ToolTip="Folder where PcaWorks26.ini will be created"/>
                        <Button x:Name="BtnBrowseIni" Content="Browse…" Grid.Column="1"
                                Style="{StaticResource SmallBtn}" Margin="4,0,0,0"
                                Click="BtnBrowseIni_Click"/>
                    </Grid>
                </Grid>
            </GroupBox>

            <!-- Activity Console -->
            <GroupBox Header="Activity" Padding="4,4,4,4" Margin="0,0,0,6">
                <Border BorderBrush="#333333" BorderThickness="1" CornerRadius="2">
                    <ScrollViewer x:Name="ConsoleScroller"
                                  Height="140"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  Background="Black">
                        <TextBox x:Name="TxtConsole"
                                 Background="Black"
                                 Foreground="#00FF00"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 BorderThickness="0"
                                 IsReadOnly="True"
                                 TextWrapping="NoWrap"
                                 VerticalAlignment="Top"
                                 Padding="4,2"
                                 Text=""/>
                    </ScrollViewer>
                </Border>
            </GroupBox>

            <!-- Status bar -->
            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="2" Padding="4,2">
                <TextBlock x:Name="TxtStatus" Text="Ready." FontSize="11" Foreground="#444444" TextWrapping="Wrap"/>
            </Border>

        </StackPanel>
    </DockPanel>
</Window>
